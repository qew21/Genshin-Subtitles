<Window x:Class="GI_Subtitles.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GI_Subtitles.Views"
        mc:Ignorable="d"
        WindowStyle="None" Height="20"  ShowInTaskbar="False" Topmost="True" Background="Transparent" AllowsTransparency="True" MouseDown="Window_MouseDown" Cursor="Hand">
    <Grid Background="Transparent">
        <!-- Content always fixed at the center position -->
        <Button x:Name="DragButton"
                Width="20" Height="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Background="#00FFFFFF"
                BorderThickness="0"
                Cursor="SizeAll" 
            Visibility="Hidden"
                 Panel.ZIndex="8">
            <Image Source="../Resources/drag.png" MouseDown="DragButton_MouseDown" Stretch="Uniform" Width="20" Height="20"  HorizontalAlignment="Center"
                VerticalAlignment="Center" />
        </Button>
        <TextBox x:Name="SubtitleText"
                 TextWrapping="Wrap"
                 Foreground="White"
                 TextAlignment="Center"
                 FontWeight="Bold"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Center"
                 Background="Transparent"
                 BorderThickness="0"
                 IsReadOnly="True"
                 AcceptsReturn="True"/>
        
        <!-- Header displayed above the content, centered display, using negative Margin to locate above the content -->
        <TextBlock x:Name="HeaderText" TextWrapping="Wrap" Foreground="White" 
                   TextAlignment="Center" FontWeight="Bold" FontSize="14" 
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Margin="0,0,0,0" Visibility="Collapsed">
            <TextBlock.RenderTransform>
                <TranslateTransform Y="-20"/>
            </TextBlock.RenderTransform>
        </TextBlock>
    </Grid>
</Window>

